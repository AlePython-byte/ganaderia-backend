# Ganaderia 4.0 Backend
# Copy to .env locally. Do not commit real secrets.
# GEMINI_API_KEY must never be committed.
# APP_NOTIFICATIONS_EMAIL_API_KEY must never be committed.
# JWT_SECRET must be long and private.
# DEVICE_SECRET_MASTER_KEY should not be rotated in production without understanding device impact.
# AI_ENABLED=false is valid; the backend should use its rule-based fallback.
# For frontend access, APP_CORS_ALLOWED_ORIGINS should include http://localhost:5173 and the real deployed frontend domain.
# On Render, prefer SPRING_PROFILES_ACTIVE=prod and SERVER_PORT=10000 (or let Render inject PORT).

########################################
# Required runtime secrets
########################################
DB_URL=jdbc:postgresql://localhost:5432/ganaderia4
DB_USERNAME=postgres
DB_PASSWORD=change-me
JWT_SECRET=change-me-long-random-private-secret-at-least-32-bytes
DEVICE_SECRET_MASTER_KEY=change-me-long-random-private-device-master-key

########################################
# Profiles and port
########################################
SPRING_PROFILES_ACTIVE=local
SPRING_PROFILES_DEFAULT=local
SERVER_PORT=8080
# PORT=8080

########################################
# CORS
########################################
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
# Render/Vercel example:
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://tu-frontend.vercel.app

########################################
# AI / Gemini
########################################
AI_ENABLED=false
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_CONNECT_TIMEOUT=5s
GEMINI_READ_TIMEOUT=10s

########################################
# Bootstrap admin (optional)
########################################
APP_BOOTSTRAP_ADMIN_ENABLED=true
APP_BOOTSTRAP_ADMIN_NAME=
APP_BOOTSTRAP_ADMIN_EMAIL=
APP_BOOTSTRAP_ADMIN_PASSWORD=
APP_BOOTSTRAP_ADMIN_UPDATE_EXISTING=false
APP_BOOTSTRAP_ADMIN_RESET_PASSWORD=false

########################################
# Webhook / notifications (optional)
########################################
APP_NOTIFICATIONS_WEBHOOK_ENABLED=false
APP_NOTIFICATIONS_WEBHOOK_URL=
APP_NOTIFICATIONS_WEBHOOK_SECRET=
APP_NOTIFICATIONS_WEBHOOK_PROCESSOR_ENABLED=true
APP_NOTIFICATIONS_WEBHOOK_MAX_ATTEMPTS=3
APP_NOTIFICATIONS_WEBHOOK_CONNECT_TIMEOUT=5s
APP_NOTIFICATIONS_WEBHOOK_READ_TIMEOUT=5s
APP_NOTIFICATIONS_WEBHOOK_PROCESSOR_FIXED_DELAY=15s
APP_NOTIFICATIONS_WEBHOOK_PROCESSOR_BATCH_SIZE=20
APP_NOTIFICATIONS_WEBHOOK_RETRY_BACKOFF=30s
APP_NOTIFICATIONS_EMAIL_ENABLED=false
APP_NOTIFICATIONS_EMAIL_PROVIDER=resend
APP_NOTIFICATIONS_EMAIL_API_KEY=
APP_NOTIFICATIONS_EMAIL_FROM=
APP_NOTIFICATIONS_EMAIL_TO=
APP_NOTIFICATIONS_EMAIL_CONNECT_TIMEOUT_MS=3000
APP_NOTIFICATIONS_EMAIL_READ_TIMEOUT_MS=5000
APP_NOTIFICATIONS_EMAIL_BASE_URL=https://api.resend.com
APP_DEVICE_REPLAY_NONCE_CLEANUP_ENABLED=true
APP_DEVICE_REPLAY_NONCE_CLEANUP_FIXED_DELAY=10m
APP_DEVICE_REPLAY_NONCE_CLEANUP_RETENTION=30m

########################################
# Abuse protection (optional)
########################################
APP_ABUSE_PROTECTION_ENABLED=true
APP_ABUSE_PROTECTION_CLEANUP_ENABLED=true
APP_ABUSE_PROTECTION_CLEANUP_FIXED_DELAY=30m
APP_ABUSE_PROTECTION_CLEANUP_RETENTION=24h
APP_ABUSE_PROTECTION_TRUST_FORWARDED_HEADERS=false
APP_ABUSE_PROTECTION_LOGIN_ENABLED=true
APP_ABUSE_PROTECTION_LOGIN_WINDOW=15m
APP_ABUSE_PROTECTION_LOGIN_MAX_ATTEMPTS=5
APP_ABUSE_PROTECTION_LOGIN_BLOCK_DURATION=15m
APP_ABUSE_PROTECTION_DEVICE_ENABLED=true
APP_ABUSE_PROTECTION_DEVICE_WINDOW=1m
APP_ABUSE_PROTECTION_DEVICE_MAX_ATTEMPTS=300
APP_ABUSE_PROTECTION_DEVICE_BLOCK_DURATION=5m

########################################
# SQL logging (optional; keep off by default)
########################################
APP_SQL_LOGGING_ENABLED=false
APP_SQL_LOG_LEVEL=OFF
APP_SQL_BIND_LOG_LEVEL=OFF

########################################
# Operational extras (optional)
########################################
JWT_EXPIRATION_MS=86400000
APP_AUTH_PASSWORD_RESET_TOKEN_TTL=15m
APP_FRONTEND_PASSWORD_RESET_URL=http://localhost:5173/reset-password
DEVICE_AUTH_WINDOW_SECONDS=300
DEVICE_HMAC_PEPPER=
REPORT_ALERTS_CSV_MAX_ROWS=5000
APP_PAGINATION_DEFAULT_SIZE=20
APP_PAGINATION_MAX_SIZE=100
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
APP_DEVICE_MONITOR_OFFLINE_THRESHOLD_MINUTES=15
APP_DEVICE_MONITOR_OFFLINE_CHECK_MS=60000

########################################
# Minimal local example
########################################
# SPRING_PROFILES_ACTIVE=local
# DB_URL=jdbc:postgresql://localhost:5432/ganaderia4
# DB_USERNAME=postgres
# DB_PASSWORD=change-me
# JWT_SECRET=change-me-long-random-private-secret-at-least-32-bytes
# DEVICE_SECRET_MASTER_KEY=change-me-long-random-private-device-master-key
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
# AI_ENABLED=false

########################################
# Minimal Render example
########################################
# SPRING_PROFILES_ACTIVE=prod
# SERVER_PORT=10000
# DB_URL=jdbc:postgresql://<host>:5432/<database>
# DB_USERNAME=<user>
# DB_PASSWORD=<password>
# JWT_SECRET=<long-private-secret>
# DEVICE_SECRET_MASTER_KEY=<long-private-secret>
# APP_CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app
# AI_ENABLED=false
